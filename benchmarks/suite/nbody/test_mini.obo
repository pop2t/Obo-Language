use Math;
entity Body { x; y; z; vx; vy; vz; mass; }

function energy(bodies, nbodies)
{
    e = 0.0;
    count(i = 0, nbodies)
    {
        bi = bodies[i];
        show "body " + i + ": vx=" + bi.vx + " vy=" + bi.vy + " mass=" + bi.mass;
        ke = 0.5 * bi.mass * (bi.vx * bi.vx + bi.vy * bi.vy + bi.vz * bi.vz);
        show "  KE=" + ke;
        count(j = i + 1, nbodies)
        {
            bj = bodies[j];
            dx = bi.x - bj.x;
            dy = bi.y - bj.y;
            dz = bi.z - bj.z;
            dist = Math.sqrt(dx * dx + dy * dy + dz * dz);
            pe = bi.mass * bj.mass / dist;
            show "  PE(" + i + "," + j + ")=" + pe + " dist=" + dist;
            e = e - pe;
        }
        e = e + ke;
    }
    out e;
}

function main()
{
    solar_mass = 4.0 * Math.pi * Math.pi;
    days_per_year = 365.24;

    sun = Body {
        x = 0.0; y = 0.0; z = 0.0;
        vx = 0.0; vy = 0.0; vz = 0.0;
        mass = solar_mass;
    };

    jupiter = Body {
        x = 4.84143144246472090;
        y = -1.16032004402742839;
        z = -0.103622044471123109;
        vx = 0.00166007664274403694 * days_per_year;
        vy = 0.00769901118419740425 * days_per_year;
        vz = -0.0000690460016972063023 * days_per_year;
        mass = 0.000954791938424326609 * solar_mass;
    };

    bodies = [sun, jupiter];
    show "solar_mass=" + solar_mass;
    show "sun.mass=" + sun.mass;
    show "jupiter.mass=" + jupiter.mass;
    show "jupiter.vx=" + jupiter.vx;
    show energy(bodies, 2);
}

main();
