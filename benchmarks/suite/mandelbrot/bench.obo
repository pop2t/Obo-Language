/// OBO Speed Benchmark: Mandelbrot Set
/// Tests: floating-point arithmetic, tight loop compute, --no-gc
/// Pure compute — no allocations, no GC pressure

function main()
{
    size = 2000;
    max_iter = 50;
    total = 0;

    count(py = 0, size)
    {
        count(px = 0, size)
        {
            x0 = (px * 3.5 / size) - 2.5;
            y0 = (py * 2.0 / size) - 1.0;
            x = 0.0;
            y = 0.0;
            iter = 0;
            while (iter < max_iter)
            {
                if (x * x + y * y > 4.0) { stop; }
                xt = x * x - y * y + x0;
                y = 2.0 * x * y + y0;
                x = xt;
                iter = iter + 1;
            }
            total = total + iter;
        }
    }

    show "Mandelbrot " + size + "x" + size + ": " + total;
}

main();
