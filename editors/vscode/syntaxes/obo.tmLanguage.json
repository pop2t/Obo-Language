{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "OBO",
  "scopeName": "source.obo",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.obo",
          "match": "//.*$"
        },
        {
          "name": "comment.line.doc.obo",
          "match": "///.*$"
        },
        {
          "name": "comment.block.obo",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.obo",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            {
              "name": "constant.character.escape.obo",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.obo",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [{ "include": "$self" }]
            }
          ]
        },
        {
          "name": "string.quoted.double.obo",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.obo",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.obo",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [{ "include": "$self" }]
            }
          ]
        },
        {
          "name": "string.quoted.single.obo",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.obo",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.obo",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.obo",
          "match": "\\b0b[01]+\\b"
        },
        {
          "name": "constant.numeric.decimal.obo",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.obo",
          "match": "\\b(if|else|while|forever|count|for|in|check|is|stop|restart|out|wait|then|possible)\\b"
        },
        {
          "name": "keyword.declaration.obo",
          "match": "\\b(function|entity|actor|choice|trait|system|template|final|shared|public|property|extend|type|const|event|operator|override)\\b"
        },
        {
          "name": "keyword.operator.logical.obo",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.other.obo",
          "match": "\\b(of|as|to|step|from|use|has|action|emit|listen|run|channel|safe|metal|bridge|gc|show|prompt|into|assert|inspect)\\b"
        },
        {
          "name": "keyword.type.obo",
          "match": "\\b(number|decimal|text|flag|nothing|any|byte|bits|pointer|atomic)\\b"
        },
        {
          "name": "keyword.collection.obo",
          "match": "\\b(list|map|set|bag|queue|stack|grid2d|grid3d|pair|slice|buffer)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.obo",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.obo",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.obo",
          "match": "(=>|\\|>|\\.\\.\\.|==|!=|<=|>=|<|>|\\+|-|\\*|/|%|=)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.obo",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.obo",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
