{
  "name": "obo-lang",
  "displayName": "OBO Language",
  "description": "Language support for the OBO programming language",
  "version": "0.5.0",
  "publisher": "obo",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:obo"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "obo",
        "aliases": [
          "OBO",
          "obo"
        ],
        "extensions": [
          ".obo"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "obo",
        "scopeName": "source.obo",
        "path": "./syntaxes/obo.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "OBO",
      "properties": {
        "obo.serverPath": {
          "type": "string",
          "default": "obo",
          "description": "Path to the obo binary (used for the language server)"
        }
      }
    },
    "commands": [
      {
        "command": "obo.runFile",
        "title": "Run OBO File",
        "icon": "$(play)",
        "category": "OBO"
      },
      {
        "command": "obo.buildFile",
        "title": "Build OBO File (Native)",
        "icon": "$(gear)",
        "category": "OBO"
      },
      {
        "command": "obo.checkFile",
        "title": "Check OBO File",
        "icon": "$(check)",
        "category": "OBO"
      },
      {
        "command": "obo.testFile",
        "title": "Test OBO File",
        "icon": "$(beaker)",
        "category": "OBO"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "obo.runFile",
          "when": "resourceLangId == obo",
          "group": "1_run@1"
        },
        {
          "command": "obo.buildFile",
          "when": "resourceLangId == obo",
          "group": "1_run@2"
        },
        {
          "command": "obo.checkFile",
          "when": "resourceLangId == obo",
          "group": "1_run@3"
        },
        {
          "command": "obo.testFile",
          "when": "resourceLangId == obo",
          "group": "1_run@4"
        }
      ]
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "package": "npm run compile && npx @vscode/vsce package --no-dependencies --allow-missing-repository"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0"
  }
}
