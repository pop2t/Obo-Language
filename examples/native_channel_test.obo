function main() {
    ch = channel();
    
    _producer = run action() {
        count(i = 0, 10) {
            ch.send(i);
        }
    };
    
    sum = 0;
    count(i = 0, 10) {
        val = ch.receive();
        sum = sum + val;
    }
    
    show "Sum of 0..9 = " + sum;
    wait for all;
}
